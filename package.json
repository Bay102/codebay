{
 "name": "codebay-monorepo",
 "private": true,
 "version": "1.0.0",
 "license": "UNLICENSED",
 "packageManager": "npm@10.9.2",
 "workspaces": [
  "apps/*",
  "packages/*"
 ],
 "scripts": {
  "dev": "NEXT_IGNORE_INCORRECT_LOCKFILE=true turbo run dev --parallel",
  "dev:codebay": "NEXT_IGNORE_INCORRECT_LOCKFILE=true turbo run dev --filter=@codebay/codebay",
  "dev:blog": "NEXT_IGNORE_INCORRECT_LOCKFILE=true turbo run dev --filter=@codebay/blog",
  "dev:community": "NEXT_IGNORE_INCORRECT_LOCKFILE=true turbo run dev --filter=@codebay/community",
  "build": "turbo run build",
  "lint": "turbo run lint",
  "test": "turbo run test"
 },
 "devDependencies": {
  "turbo": "^2.5.6"
 }
}
