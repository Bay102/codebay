NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# For local dev; in production set NEXT_PUBLIC_COMMUNITY_SITE_URL to your live URL (e.g. https://codingbay.community)
NEXT_PUBLIC_COMMUNITY_SITE_URL=http://localhost:3002
NEXT_PUBLIC_MAIN_URL=http://localhost:3000

OPENAI_API_KEY=your_openai_api_key

# Newsletter environment variables
NEWSLETTER_UNSUBSCRIBE_SECRET=your_newsletter_unsubscribe_secret
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
CRON_SECRET=your_cron_secret
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=your_resend_from_email